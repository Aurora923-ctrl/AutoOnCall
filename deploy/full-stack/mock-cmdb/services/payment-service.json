{
  "service_name": "payment-service",
  "owner": "payments-oncall",
  "tier": "critical",
  "environment": "prod",
  "namespace": "payments",
  "runtime": "kubernetes",
  "dependencies": [
    {
      "name": "mysql-payments",
      "type": "mysql",
      "endpoint": "mysql:3306"
    },
    {
      "name": "redis-payment-cache",
      "type": "redis",
      "endpoint": "redis:6379"
    }
  ],
  "slo": {
    "availability": "99.9%",
    "p95_latency_ms": 800
  }
}
