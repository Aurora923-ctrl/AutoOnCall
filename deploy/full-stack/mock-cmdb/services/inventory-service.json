{
  "service_name": "inventory-service",
  "owner": "supply-chain-oncall",
  "tier": "critical",
  "environment": "prod",
  "namespace": "inventory",
  "runtime": "kubernetes",
  "dependencies": [
    {
      "name": "mysql-inventory",
      "type": "mysql",
      "endpoint": "mysql:3306"
    },
    {
      "name": "redpanda-inventory",
      "type": "kafka",
      "endpoint": "redpanda:9092"
    }
  ],
  "slo": {
    "availability": "99.95%",
    "p95_latency_ms": 600
  }
}
