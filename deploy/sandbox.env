# Local AIOps sandbox adapter configuration.
# Load these values into the FastAPI process environment, or copy them into .env for a demo run.

AIOPS_MOCK_FALLBACK_ENABLED=false
AIOPS_STORE_RAW_EXTERNAL_PAYLOAD=false

PROMETHEUS_BASE_URL=http://127.0.0.1:19090
PROMETHEUS_QPS_QUERY=autooncall_http_qps{service="{service_name}"}
PROMETHEUS_ERROR_RATE_QUERY=autooncall_http_5xx_rate{service="{service_name}"}
PROMETHEUS_P95_QUERY=autooncall_p95_latency_ms{service="{service_name}"}
PROMETHEUS_CPU_QUERY=autooncall_cpu_usage_percent{service="{service_name}"}
PROMETHEUS_MEMORY_QUERY=autooncall_memory_working_set_bytes{service="{service_name}"}

REDIS_HOST=127.0.0.1
REDIS_PORT=16379
REDIS_ALLOW_ADMIN_COMMANDS=true
REDIS_INSTANCES={"redis-cluster-prod":"redis://127.0.0.1:16379/0"}

MYSQL_DSN=mysql+pymysql://autooncall:autooncall123@127.0.0.1:13306/autooncall?charset=utf8mb4
MYSQL_INSTANCES={"order-mysql":"mysql+pymysql://autooncall:autooncall123@127.0.0.1:13306/autooncall?charset=utf8mb4","payment-mysql":"mysql+pymysql://autooncall:autooncall123@127.0.0.1:13306/autooncall?charset=utf8mb4"}

LOKI_BASE_URL=http://127.0.0.1:13100
KUBERNETES_NAMESPACE=default
KUBERNETES_VERIFY_SSL=false
