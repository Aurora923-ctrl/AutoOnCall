# AutoOnCall production-oriented environment example.
# Copy values into your deployment secret manager or local .env; do not commit real secrets.

APP_NAME=AutoOnCall
APP_VERSION=1.2.1
DEBUG=false
HOST=0.0.0.0
PORT=9900
# Fail closed when binding to a non-local host with unsafe demo defaults.
# Local-only demos may set this to false.
PRODUCTION_EXPOSURE_STRICT=true

DASHSCOPE_API_KEY=replace-with-secret
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSIONS=1024
DASHSCOPE_EMBEDDING_BATCH_SIZE=10
DASHSCOPE_EMBEDDING_MAX_RETRIES=2
DASHSCOPE_EMBEDDING_TIMEOUT_SECONDS=30
RAG_MODEL=qwen-max
RAG_MODEL_TIMEOUT_SECONDS=60
RAG_MODEL_MAX_RETRIES=1
RAG_MODEL_RETRY_DELAY_SECONDS=0.25
RAG_STREAM_SPOOL_MAX_MEMORY_BYTES=1048576

MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000
MILVUS_CONNECT_MAX_RETRIES=2
MILVUS_CONNECT_RETRY_DELAY_SECONDS=0.5
MILVUS_RECREATE_ON_DIMENSION_MISMATCH=false
# Docker Compose host persistence root. Override this on macOS/Linux or another Windows drive.
AUTOONCALL_MILVUS_DATA_ROOT=D:/AppDataStorage/DockerData/autooncall/milvus
# Host persistence roots for the two local AIOps adapter stacks.
AUTOONCALL_FULL_STACK_DATA_ROOT=D:/AppDataStorage/DockerData/autooncall
AUTOONCALL_INTERVIEW_DATA_ROOT=D:/AppDataStorage/DockerData/autooncall-full
# Local-only defaults; set strong secret-manager values outside a loopback demo.
MILVUS_MINIO_ROOT_USER=minioadmin
MILVUS_MINIO_ROOT_PASSWORD=minioadmin
# Compose-only local MySQL defaults. Override them before any shared deployment.
AUTOONCALL_MYSQL_ROOT_PASSWORD=123456
AUTOONCALL_MYSQL_DATABASE=autooncall
AUTOONCALL_MYSQL_USER=autooncall
AUTOONCALL_MYSQL_PASSWORD=autooncall123
# Optional seed identity. Defaults to root and uses AUTOONCALL_MYSQL_ROOT_PASSWORD.
AUTOONCALL_MYSQL_SEED_USER=root

RAG_TOP_K=3
RAG_MAX_L2_DISTANCE=2.0
RAG_MIN_LEXICAL_TRUST_SCORE=0.20
RAG_CONTENT_PREVIEW_CHARS=240
RAG_RETRIEVAL_FUSION_STRATEGY=weighted
UPLOAD_ALLOWED_EXTENSIONS=txt,md,markdown,pdf,html,htm,csv,xlsx
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100
INDEX_ALLOWED_ROOTS=uploads,docs/knowledge-base

# AIOps runtime state: sqlite by default, mysql for production-oriented deployments.
AIOPS_STORAGE_BACKEND=sqlite
AIOPS_SQLITE_PATH=data/aiops_state.db
ALERT_AUTO_DIAGNOSIS_TIMEOUT_SECONDS=900
EVAL_SUMMARY_PATH=logs/eval_summary.json
EVAL_BACKLOG_PATH=logs/eval_backlog_drafts.json

# Optional RAGAS quality evaluation. This is intended for manual/nightly/interview
# quality reports, not the default production startup path.
# The default CLI profile is id-smoke, which does not require a judge key. Set
# RAGAS_EVAL_MODEL / RAGAS_EVAL_EMBEDDING_MODEL only for --metrics-profile full.
RAGAS_EVAL_ENABLED=false
RAGAS_EVAL_SUMMARY_PATH=logs/ragas_eval_summary.json
RAGAS_EVAL_MODEL=
RAGAS_EVAL_EMBEDDING_MODEL=
RAGAS_MIN_FAITHFULNESS=0.85
RAGAS_MIN_RESPONSE_RELEVANCY=0.80
RAGAS_MIN_ID_CONTEXT_PRECISION=0.75
RAGAS_MIN_ID_CONTEXT_RECALL=0.75
RAGAS_MIN_ONCALL_ACTIONABILITY=0.80

# Example:
# AIOPS_STORAGE_BACKEND=mysql
# MYSQL_DSN=mysql+pymysql://autooncall:replace-with-secret@mysql:3306/autooncall?charset=utf8mb4
# Production-oriented default: unconfigured adapters return structured failures instead of deterministic mock data.
# Local demos may override this to true.
AIOPS_MOCK_FALLBACK_ENABLED=false
# Optional: let Replanner call the structured LLM critic after deterministic evidence analysis.
AIOPS_REPLANNER_LLM_ENABLED=false
# Oversized tool outputs are stored as redacted local artifacts; Trace/Report keeps only pointers.
AIOPS_TOOL_OUTPUT_ARTIFACT_DIR=data/aiops_tool_artifacts
AIOPS_TOOL_OUTPUT_INLINE_BYTES=20000

# Optional A2A northbound agent interface. Keep disabled unless another trusted
# agent runtime needs to call AutoOnCall diagnosis/read-only capabilities.
A2A_ENABLED=false
A2A_BASE_PATH=/a2a/v1
A2A_AGENT_NAME=AutoOnCall Diagnosis Agent

# Backup settings are deployment hooks; the application does not start a backup scheduler by itself.
SQLITE_BACKUP_ENABLED=false
SQLITE_BACKUP_DIR=data/backups
LOG_RETENTION_DAYS=14

# Optional internal API-token RBAC. Keep disabled for local demos; enable in stricter
# internal environments and configure at least one token. Prefer secret-manager values.
API_AUTH_ENABLED=true
# Tokens shorter than 16 characters or obvious placeholder values are rejected.
API_READ_TOKEN=
API_OPERATOR_TOKEN=
API_APPROVER_TOKEN=
API_CHANGE_TOKEN=
API_ADMIN_TOKEN=
# Advanced token map. Keys are token values; values are roles/scopes.
# Example: API_AUTH_TOKENS={"viewer-token":["viewer"],"ops-token":["operator"],"approver-token":["approver"],"change-token":["change_operator"],"admin-token":["admin"]}
API_AUTH_TOKENS=

# Comma-separated browser origins. Avoid "*" in production.
CORS_ALLOWED_ORIGINS=https://autooncall.example.com,https://ops.example.com

# Prometheus adapter. Leave blank in strict mode to return structured not_configured evidence.
#
# OpenTelemetry exports are optional locally. Set an OTLP/HTTP collector base endpoint
# such as http://otel-collector:4318 in staging or production.
OTEL_SERVICE_NAME=autooncall
OTEL_ENVIRONMENT=local
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORT_TIMEOUT_SECONDS=5
OTEL_METRIC_EXPORT_INTERVAL_SECONDS=30
OTEL_INSTRUMENT_FASTAPI=true
OTEL_EXCLUDED_URLS=health/live
DEPENDENCY_CIRCUIT_FAILURE_THRESHOLD=5
DEPENDENCY_CIRCUIT_RECOVERY_SECONDS=30

# Prometheus adapter. Leave blank in strict mode to return structured not_configured evidence.
PROMETHEUS_BASE_URL=
PROMETHEUS_BEARER_TOKEN=
PROMETHEUS_TIMEOUT_SECONDS=5

# Log gateway adapter. This should point to an internal CLS/Loki/OpenSearch facade.
LOG_GATEWAY_URL=
LOG_GATEWAY_BEARER_TOKEN=
LOG_GATEWAY_TIMEOUT_SECONDS=8


# Kubernetes read-only adapter.
KUBERNETES_API_SERVER=
KUBERNETES_NAMESPACE=default
KUBERNETES_BEARER_TOKEN=
KUBERNETES_VERIFY_SSL=true
KUBERNETES_TIMEOUT_SECONDS=8

# Redis INFO adapter. Use a read-only or least-privilege account where possible.
# Local host-to-container example: REDIS_HOST=127.0.0.1 and REDIS_PORT=16379.
# If the app also runs inside Docker, use the Redis service name and container port 6379.
REDIS_URL=
REDIS_HOST=
REDIS_PORT=16379
REDIS_PASSWORD=
REDIS_INSTANCES=
# Example: REDIS_INSTANCES={"redis-cluster-prod":"redis://127.0.0.1:16379/0"}
REDIS_ALLOW_ADMIN_COMMANDS=false
REDIS_TIMEOUT_SECONDS=5

# Optional MySQL adapter. Requires PyMySQL in the runtime image. The local interview sandbox
# also stores service catalog, deploy history, and historical tickets in MySQL tables.
# Local host-to-container example:
# MYSQL_DSN=mysql+pymysql://autooncall:autooncall123@127.0.0.1:13306/autooncall?charset=utf8mb4
# If the app also runs inside Docker, use the MySQL service name and container port 3306.
MYSQL_DSN=
MYSQL_URL=
MYSQL_HOST=
MYSQL_PORT=13306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_INSTANCES=
# Example: MYSQL_INSTANCES={"order-mysql":"mysql+pymysql://autooncall:autooncall123@127.0.0.1:13306/autooncall?charset=utf8mb4"}
MYSQL_TIMEOUT_SECONDS=5
MYSQL_POOL_SIZE=10
MYSQL_POOL_MAX_OVERFLOW=5

# Store complete external raw payloads before artifact compaction. Keep false in production unless debugging.
AIOPS_STORE_RAW_EXTERNAL_PAYLOAD=false

# Optional business-context HTTP adapters. Leave blank for the local interview sandbox so
# CMDB, deploy history, and ticket evidence come from the real MySQL seed tables instead
# of separate mock HTTP services.
CMDB_API_URL=
CMDB_API_BEARER_TOKEN=
CMDB_API_TIMEOUT_SECONDS=8
DEPLOY_HISTORY_API_URL=
DEPLOY_HISTORY_API_BEARER_TOKEN=
DEPLOY_HISTORY_API_TIMEOUT_SECONDS=8
TICKET_API_URL=
TICKET_API_BEARER_TOKEN=
TICKET_API_TIMEOUT_SECONDS=8

# MCP tool discovery uses one bounded total timeout per agent initialization.
MCP_DISCOVERY_TIMEOUT_SECONDS=5

# Local proof-of-live-data sandbox:
#   make sandbox-up
#   make sandbox-demo
# Or copy deploy/sandbox.env into your process environment before starting FastAPI.
