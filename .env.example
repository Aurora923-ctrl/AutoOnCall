# AutoOnCall production-oriented environment example.
# Copy values into your deployment secret manager or local .env; do not commit real secrets.

APP_NAME=AutoOnCall
APP_VERSION=1.2.1
DEBUG=false
HOST=0.0.0.0
PORT=9900

DASHSCOPE_API_KEY=replace-with-secret
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
RAG_MODEL=qwen-max

MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000
MILVUS_RECREATE_ON_DIMENSION_MISMATCH=false

RAG_TOP_K=3
RAG_MAX_L2_DISTANCE=2.0
RAG_CONTENT_PREVIEW_CHARS=240
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100
INDEX_ALLOWED_ROOTS=uploads,aiops-docs

# AIOps runtime state: sqlite by default, mysql for production-oriented deployments.
AIOPS_STORAGE_BACKEND=sqlite
AIOPS_SQLITE_PATH=data/aiops_state.db
# Example:
# AIOPS_STORAGE_BACKEND=mysql
# MYSQL_DSN=mysql+pymysql://autooncall:replace-with-secret@mysql:3306/autooncall?charset=utf8mb4
# Keep true for local demos. Set false in stricter environments so unconfigured adapters return structured failures instead of deterministic mock data.
AIOPS_MOCK_FALLBACK_ENABLED=true
# Backup settings are deployment hooks; the application does not start a backup scheduler by itself.
SQLITE_BACKUP_ENABLED=false
SQLITE_BACKUP_DIR=data/backups
LOG_RETENTION_DAYS=14

# Optional internal API-token RBAC. Keep disabled for local demos; enable in stricter
# internal environments and configure at least one token. Prefer secret-manager values.
API_AUTH_ENABLED=false
API_READ_TOKEN=
API_OPERATOR_TOKEN=
API_APPROVER_TOKEN=
API_ADMIN_TOKEN=
# Advanced token map. Keys are token values; values are roles/scopes.
# Example: API_AUTH_TOKENS={"viewer-token":["viewer"],"ops-token":["operator"],"sre-token":["approver"],"admin-token":["admin"]}
API_AUTH_TOKENS=

# Comma-separated browser origins. Avoid "*" in production.
CORS_ALLOWED_ORIGINS=https://autooncall.example.com,https://ops.example.com

# Prometheus adapter. Leave blank to use MCP/mock fallback when AIOPS_MOCK_FALLBACK_ENABLED=true.
ALERTMANAGER_BASE_URL=
ALERTMANAGER_BEARER_TOKEN=
ALERTMANAGER_TIMEOUT_SECONDS=5

PROMETHEUS_BASE_URL=
PROMETHEUS_BEARER_TOKEN=
PROMETHEUS_TIMEOUT_SECONDS=5

# Log gateway adapter. This should point to an internal CLS/Loki/OpenSearch facade.
LOG_GATEWAY_URL=
LOG_GATEWAY_BEARER_TOKEN=
LOG_GATEWAY_TIMEOUT_SECONDS=8

JAEGER_BASE_URL=
JAEGER_BEARER_TOKEN=
JAEGER_TIMEOUT_SECONDS=8
# Tempo is used by the tracing tool when JAEGER_BASE_URL is empty.
TEMPO_BASE_URL=
TEMPO_BEARER_TOKEN=
TEMPO_TIMEOUT_SECONDS=8
REDPANDA_ADMIN_URL=
REDPANDA_BEARER_TOKEN=
REDPANDA_TIMEOUT_SECONDS=8
# Kafka bootstrap is documented for topology/deploy context only; this app's
# queue status adapter currently reads Redpanda Admin API, not Kafka metadata.
KAFKA_BOOTSTRAP_SERVERS=

# Kubernetes read-only adapter.
KUBERNETES_API_SERVER=
KUBERNETES_NAMESPACE=default
KUBERNETES_BEARER_TOKEN=
KUBERNETES_VERIFY_SSL=true
KUBERNETES_TIMEOUT_SECONDS=8

# Redis INFO adapter. Use a read-only or least-privilege account where possible.
# Local Docker example: REDIS_HOST=127.0.0.1 and REDIS_PORT=6379.
# If the app also runs inside Docker on dev-net, use REDIS_HOST=dev-redis.
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_INSTANCES=
# Example: REDIS_INSTANCES={"redis-cluster-prod":"redis://127.0.0.1:6379/0"}
REDIS_ALLOW_ADMIN_COMMANDS=true
REDIS_TIMEOUT_SECONDS=5

# Optional MySQL adapter. Requires PyMySQL in the runtime image.
# Local Docker example:
# MYSQL_DSN=mysql+pymysql://autooncall:autooncall123@127.0.0.1:3306/autooncall?charset=utf8mb4
# If the app also runs inside Docker on dev-net, replace 127.0.0.1 with dev-mysql.
MYSQL_DSN=
MYSQL_URL=
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_INSTANCES=
# Example: MYSQL_INSTANCES={"order-mysql":"mysql+pymysql://autooncall:autooncall123@127.0.0.1:3306/autooncall?charset=utf8mb4"}
MYSQL_TIMEOUT_SECONDS=5

# Store complete external raw payloads in Trace/Report. Keep false in production unless debugging.
AIOPS_STORE_RAW_EXTERNAL_PAYLOAD=false

# Local proof-of-live-data sandbox:
#   make sandbox-up
#   make sandbox-demo
# Or copy deploy/sandbox.env into your process environment before starting FastAPI.

# Historical ticket adapter.
TICKET_API_URL=
TICKET_API_BEARER_TOKEN=
TICKET_API_TIMEOUT_SECONDS=8
